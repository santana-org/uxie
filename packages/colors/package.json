{
  "name": "@santana-org/colors",
  "version": "0.2.0",
  "description": "Minimal TypeScript color utility library with parsing, conversion, and fluent manipulation",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/santana-org/uxie.git",
    "directory": "packages/colors"
  },
  "keywords": ["color", "colors", "hex", "rgb", "hsl", "typescript", "esm", "santana-org"],
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "unbuild",
    "dev": "unbuild --stub",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "packcheck": "publint"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "publint": "^0.3.4",
    "typescript": "^5.8.2",
    "unbuild": "^3.3.1",
    "vitest": "^3.0.8"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=25"
  }
}
