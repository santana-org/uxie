{
  "name": "@santana-org/faker",
  "version": "0.1.0",
  "description": "A comprehensive fake data generator for TypeScript/JavaScript - generate realistic test data for names, addresses, emails, and more",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/santana-org/uxie.git",
    "directory": "packages/faker"
  },
  "keywords": [
    "faker",
    "fake",
    "data",
    "generator",
    "mock",
    "test",
    "testing",
    "random",
    "name",
    "address",
    "email",
    "phone",
    "company",
    "lorem",
    "typescript",
    "esm"
  ],
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "unbuild",
    "dev": "unbuild --stub",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "packcheck": "publint"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "publint": "^0.3.4",
    "typescript": "^5.8.2",
    "unbuild": "^3.3.1",
    "vitest": "^3.0.8"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=25"
  }
}
